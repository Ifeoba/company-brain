\f0\fs24 \cf0 \{\
  "_description": "Runtime configuration for the Company Brain Runtime. All tool references are connector types, resolved via company-profile.json.",\
  \
  "connectors": \{\
    "enabled": ["messaging", "support", "crm", "payments", "docs"],\
    "messaging": \{\
      "listen_channels": ["#ops", "#billing-alerts"],\
      "allowed_event_types": ["new_message"],\
      "filter_rules": [\
        \{ "field": "subtype", "operator": "not_equals", "value": "bot_message" \}\
      ],\
      "retry_on_failure": true,\
      "max_reconnect_attempts": 5\
    \},\
    "support": \{\
      "allowed_event_types": ["new_ticket", "ticket_updated"],\
      "filter_rules": [],\
      "retry_on_failure": true,\
      "max_reconnect_attempts": 5\
    \},\
    "crm": \{\
      "allowed_event_types": ["customer_updated"],\
      "listen_for_webhooks": true,\
      "retry_on_failure": false\
    \},\
    "payments": \{\
      "allowed_event_types": ["refund_processed", "charge_failed"],\
      "retry_on_failure": false\
    \},\
    "docs": \{\
      "allowed_event_types": ["document_updated"],\
      "poll_interval_seconds": 300,\
      "retry_on_failure": true\
    \}\
  \},\
\
  "ingestion": \{\
    "event_batch_size": 10,\
    "batch_timeout_ms": 500,\
    "duplicate_detection_window_seconds": 300,\
    "incoming_event_queue_max_size": 10000,\
    "event_validation": "strict"\
  \},\
\
  "maintainer_triggers": \{\
    "correction_cluster_threshold": 3,\
    "correction_window_days": 7,\
    "drift_scan_interval_days": 30,\
    "stale_rule_days": 90,\
    "override_rate_high_threshold": 0.2,\
    "escalation_spike_threshold": 10,\
    "escalation_spike_window_days": 7,\
    "auto_trigger_maintainer": true,\
    "minimum_events_before_scan": 50\
  \},\
\
  "execution": \{\
    "max_concurrent_workflows": 5,\
    "workflow_default_timeout_ms": 3600000,\
    "step_default_timeout_ms": 60000,\
    "auto_approval_timeout_ms": 3600000,\
    "human_approval_queue_poll_interval_ms": 5000,\
    "retry_policy": \{\
      "max_attempts": 3,\
      "backoff": "exponential",\
      "initial_delay_ms": 1000,\
      "max_delay_ms": 30000\
    \},\
    "on_step_failure_default": "retry_then_stop",\
    "global_error_handling": \{\
      "strategy": "escalate_to_human",\
      "escalation_channel_capability": "send_message",\
      "escalation_target": "ops_channel"\
    \}\
  \},\
\
  "workflow_state_engine": \{\
    "persistence": \{\
      "type": "json_file",\
      "path_template": "\{brain_folder\}/runtime/state/\{workflow_instance_id\}.json"\
    \},\
    "checkpoint_strategy": "after_each_step",\
    "resume_on_startup": true,\
    "max_retained_instances": 1000,\
    "completed_instance_ttl_days": 90,\
    "failed_instance_ttl_days": 180\
  \},\
\
  "observability": \{\
    "event_log": \{\
      "type": "jsonl",\
      "path_template": "\{brain_folder\}/runtime/logs/events-\{date\}.jsonl",\
      "rotation": "daily",\
      "retention_days": 365\
    \},\
    "action_log": \{\
      "type": "jsonl",\
      "path_template": "\{brain_folder\}/runtime/logs/actions-\{date\}.jsonl",\
      "retention_days": 365\
    \},\
    "metrics": \{\
      "collection_interval_seconds": 60,\
      "storage_backend": "in_memory",\
      "export_enabled": false\
    \},\
    "health_check_interval_minutes": 5,\
    "alerting": \{\
      "on_workflow_failure": true,\
      "on_escalation_spike": true,\
      "on_drift_detected": true,\
      "notification_capability": "send_message",\
      "target": "ops_channel"\
    \}\
  \},\
\
  "health_checks": \{\
    "connector_status": \{\
      "enabled": true,\
      "interval_seconds": 60,\
      "max_failures_before_alert": 3\
    \},\
    "brain_file_integrity": \{\
      "enabled": true,\
      "check_on_startup": true,\
      "required_files": [\
        "01-service-definition.md",\
        "02-how-the-work-happens.md",\
        "03-decision-rules.md",\
        "04-skills.md",\
        "05-guardrails.md"\
      ]\
    \},\
    "workflow_state_consistency": \{\
      "enabled": true,\
      "interval_minutes": 15,\
      "auto_recovery": true\
    \}\
  \}\
\}}